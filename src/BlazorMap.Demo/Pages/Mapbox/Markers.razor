@page "/mapbox/markers"
@inject IConfiguration Configuration

<PageTitle>BlazorMap — Mapbox markers</PageTitle>

<h1>Markers and popups (Mapbox)</h1>

<section class="demo-panel">
    @if (string.IsNullOrWhiteSpace(_token))
    {
        <p class="demo-warn">Configure <code>Mapbox:AccessToken</code> in <code>wwwroot/appsettings.json</code> for this sample.</p>
    }
    <p>The marker API matches Leaflet and MapLibre; Mapbox GL renders symbols and popups natively.</p>
    <div class="demo-map-wrap">
        <BlazorMapboxMap @ref="_map"
                         Height="360px"
                         Options="@_opts"
                         OnMapReady="SeedInitialMarkersAsync"
                         OnMarkerClick="HandleMarkerClick"
                         OnMarkerDragEnd="HandleMarkerDragEnd" />
    </div>
    <div class="demo-actions">
        <button type="button" @onclick="AddRandomMarkerAsync">Add marker</button>
        <button type="button" @onclick="ClearAsync">Clear all</button>
        <button type="button" @onclick="OpenLondonPopupAsync">Open London popup</button>
    </div>
    <div class="demo-log">@_log</div>
</section>

<DemoCodeSample Title="Mapbox markers" Code="@_snippet" />

@code {
    private BlazorMapboxMap? _map;
    private string _token = "";
    private string _log = "Click a pin or drag the draggable marker.";
    private int _counter;

    private BlazorMapboxMapOptions _opts = new();

    private const string _snippet =
        """
        var opts = new BlazorMapboxMapOptions
        {
            AccessToken = configuration["Mapbox:AccessToken"] ?? "",
            Center = new BlazorMapLatLng(48.8566, 2.3522),
            Zoom = 12,
        };

        <BlazorMapboxMap @ref="_map" Options="@opts" OnMapReady="SeedAsync" />
        await _map!.AddMarkerAsync(new BlazorMapMarkerModel { Id = "a", Position = ... });
        """;

    protected override void OnInitialized()
    {
        _token = Configuration["Mapbox:AccessToken"] ?? "";
        _opts = new BlazorMapboxMapOptions
        {
            AccessToken = _token,
            Center = new BlazorMapLatLng(48.8566, 2.3522),
            Zoom = 12,
        };
    }

    private async Task SeedInitialMarkersAsync()
    {
        if (_map is null || !_map.IsMapReady || string.IsNullOrWhiteSpace(_token)) return;
        await _map.AddMarkerAsync(
            new BlazorMapMarkerModel
            {
                Id = "paris",
                Position = new BlazorMapLatLng(48.8566, 2.3522),
                PopupHtml = "<b>Paris</b><br/>Built-in popup.",
                Title = "Paris",
            });
        await _map.AddMarkerAsync(
            new BlazorMapMarkerModel
            {
                Id = "london",
                Position = new BlazorMapLatLng(51.5074, -0.1278),
                PopupHtml = "<b>London</b><br/>Try “Open London popup”.",
                Draggable = true,
            });
        await _map.FitBoundsAsync(
            new BlazorMapLatLngBounds(new BlazorMapLatLng(48.75, 2.15), new BlazorMapLatLng(51.6, -0.05)));
    }

    private async Task AddRandomMarkerAsync()
    {
        if (_map is null || string.IsNullOrWhiteSpace(_token)) return;
        _counter++;
        var id = $"m{_counter}";
        var lat = 48.85 + Random.Shared.NextDouble() * 0.12;
        var lng = 2.28 + Random.Shared.NextDouble() * 0.2;
        await _map.AddMarkerAsync(
            new BlazorMapMarkerModel
            {
                Id = id,
                Position = new BlazorMapLatLng(lat, lng),
                PopupHtml = $"<span>Marker <code>{id}</code></span>",
            });
        Append($"Added {id} at {lat:F4}, {lng:F4}");
    }

    private async Task ClearAsync()
    {
        if (_map is null) return;
        await _map.ClearMarkersAsync();
        Append("Cleared markers.");
    }

    private async Task OpenLondonPopupAsync()
    {
        if (_map is null) return;
        await _map.OpenMarkerPopupAsync("london");
        Append("Requested popup for london.");
    }

    private Task HandleMarkerClick(string id)
    {
        Append($"Marker click: {id}");
        return Task.CompletedTask;
    }

    private Task HandleMarkerDragEnd((string Id, BlazorMapLatLng Position) e)
    {
        Append($"Drag end {e.Id} → {e.Position.Lat:F5}, {e.Position.Lng:F5}");
        return Task.CompletedTask;
    }

    private void Append(string line)
    {
        _log = line + Environment.NewLine + _log;
        StateHasChanged();
    }
}
