@page "/cesium/vectors"

<PageTitle>BlazorMap — CesiumJS vectors</PageTitle>

<h1>Polylines, polygons, circles, rectangles</h1>

<section class="demo-panel">
    <p>
        Vector shapes are rendered as <strong>CesiumJS entity geometry</strong>:
        <code>polyline</code>, <code>polygon</code>, <code>ellipse</code>, and <code>rectangle</code>.
        Each shape uses a string <code>layerId</code> for individual removal.
        Click a shape to raise <code>OnVectorClick</code>.
    </p>
    <div class="demo-map-wrap">
        <BlazorCesiumMap @ref="_map"
                         Height="400px"
                         Options="@_opts"
                         OnMapReady="InitialDrawAsync"
                         OnVectorClick="HandleVectorClick" />
    </div>
    <div class="demo-actions">
        <button type="button" @onclick="RedrawAsync">Redraw sample</button>
        <button type="button" @onclick="ClearAsync">Clear vectors</button>
    </div>
    <div class="demo-log">@_log</div>
</section>

<DemoCodeSample Title="Vectors API (CesiumJS)" Code="@_snippet" />

@code {
    private BlazorCesiumMap? _map;
    private string _log = "Redraw draws a route, a park polygon, a radius circle, and a bounding box.";

    private readonly BlazorCesiumMapOptions _opts = new()
    {
        Center   = new BlazorMapLatLng(37.7749, -122.4194),
        Altitude = 80_000,
    };

    private const string _snippet =
        """
        await _map.AddPolylineAsync("route", path,
            new BlazorMapVectorPathStyle { Color = "#f85149", Weight = 5 });

        await _map.AddPolygonAsync("park", ring,
            new BlazorMapVectorPathStyle { Color = "#3fb950", FillOpacity = 0.35 });

        await _map.AddCircleAsync("radius", center, radiusMeters: 900, style);

        await _map.AddRectangleAsync("box", bounds, style);

        await _map.ClearVectorLayersAsync();
        """;

    private async Task InitialDrawAsync()
    {
        if (_map is null || !_map.IsMapReady) return;
        await DrawAsync();
    }

    private async Task RedrawAsync()
    {
        if (_map is null) return;
        await DrawAsync();
        StateHasChanged();
    }

    private async Task DrawAsync()
    {
        if (_map is null) return;
        await _map.ClearVectorLayersAsync();

        await _map.AddPolylineAsync(
            "route",
            [
                new BlazorMapLatLng(37.800, -122.420),
                new BlazorMapLatLng(37.790, -122.410),
                new BlazorMapLatLng(37.780, -122.400),
                new BlazorMapLatLng(37.770, -122.395),
            ],
            new BlazorMapVectorPathStyle { Color = "#f85149", Weight = 5, Opacity = 0.9 });

        await _map.AddPolygonAsync(
            "park",
            [
                new BlazorMapLatLng(37.769, -122.486),
                new BlazorMapLatLng(37.771, -122.475),
                new BlazorMapLatLng(37.765, -122.472),
                new BlazorMapLatLng(37.762, -122.482),
            ],
            new BlazorMapVectorPathStyle { Color = "#3fb950", FillOpacity = 0.35, Weight = 2 });

        await _map.AddCircleAsync(
            "radius",
            new BlazorMapLatLng(37.7849, -122.4094),
            radiusMeters: 900,
            new BlazorMapVectorPathStyle { Color = "#58a6ff", FillOpacity = 0.15, Weight = 2 });

        await _map.AddRectangleAsync(
            "box",
            new BlazorMapLatLngBounds(new BlazorMapLatLng(37.748, -122.44), new BlazorMapLatLng(37.756, -122.42)),
            new BlazorMapVectorPathStyle { Color = "#d29922", FillOpacity = 0.12, Weight = 2 });

        await _map.FitBoundsAsync(
            new BlazorMapLatLngBounds(new BlazorMapLatLng(37.755, -122.49), new BlazorMapLatLng(37.805, -122.38)));

        _log = "Shapes drawn. Click one to see its layer id.";
    }

    private async Task ClearAsync()
    {
        if (_map is null) return;
        await _map.ClearVectorLayersAsync();
        _log = "All vector layers cleared.";
    }

    private Task HandleVectorClick((string LayerId, string Kind, BlazorMapLatLng Position) e)
    {
        _log = $"{e.Kind} \"{e.LayerId}\" @ {e.Position.Lat:F5}, {e.Position.Lng:F5}";
        return Task.CompletedTask;
    }
}
