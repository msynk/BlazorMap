@page "/cesium/geojson"

<PageTitle>BlazorMap — CesiumJS GeoJSON</PageTitle>

<h1>GeoJSON layer</h1>

<section class="demo-panel">
    <p>
        Pass any GeoJSON string to <code>AddGeoJsonAsync</code>.
        CesiumJS uses <code>GeoJsonDataSource</code> to render Polygon, LineString, and Point
        features as clamped-to-ground entities.
        Feature clicks forward <code>properties</code> as a <code>JsonElement</code>.
    </p>
    <div class="demo-map-wrap">
        <BlazorCesiumMap @ref="_map"
                         Height="400px"
                         Options="@_opts"
                         OnGeoJsonFeatureClick="HandleFeatureClick" />
    </div>
    <div class="demo-actions">
        <button type="button" @onclick="LoadAsync">Load sample</button>
        <button type="button" @onclick="ClearAsync">Remove layer</button>
    </div>
    <div class="demo-log">@_log</div>
</section>

<DemoCodeSample Title="GeoJSON (CesiumJS)" Code="@_snippet" />

@code {
    private BlazorCesiumMap? _map;
    private string _log = "Load the sample FeatureCollection, then click a feature.";

    private readonly BlazorCesiumMapOptions _opts = new()
    {
        Center   = new BlazorMapLatLng(40.75, -74.0),
        Altitude = 80_000,
    };

    private const string _snippet =
        """
        await _map.AddGeoJsonAsync(
            "demo",
            geoJsonString,
            new BlazorMapVectorPathStyle { Color = "#a371f7", Weight = 3, FillOpacity = 0.3 });

        await _map.RemoveLayerAsync("demo");
        """;

    private async Task LoadAsync()
    {
        if (_map is null) return;
        await _map.RemoveLayerAsync("demo");
        await _map.AddGeoJsonAsync(
            "demo",
            DemoGeoJsonSample.FeatureCollection,
            new BlazorMapVectorPathStyle { Color = "#a371f7", Weight = 3, FillOpacity = 0.3 });
        await _map.FitBoundsAsync(
            new BlazorMapLatLngBounds(new BlazorMapLatLng(40.71, -74.03), new BlazorMapLatLng(40.83, -73.96)));
        _log = "GeoJSON loaded. Click a feature.";
        StateHasChanged();
    }

    private async Task ClearAsync()
    {
        if (_map is null) return;
        await _map.RemoveLayerAsync("demo");
        _log = "Removed layer \"demo\".";
        StateHasChanged();
    }

    private Task HandleFeatureClick((string LayerId, JsonElement Properties) e)
    {
        var name = e.Properties.TryGetProperty("name", out var n) ? n.GetString() : "(no name)";
        _log = $"Layer {e.LayerId}, properties.name = {name}";
        return Task.CompletedTask;
    }
}
