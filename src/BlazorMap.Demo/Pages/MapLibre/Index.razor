@page "/maplibre"

<PageTitle>BlazorMap — MapLibre GL</PageTitle>

<h1>MapLibre GL</h1>

<section class="demo-panel">
    <p>
        <code>BlazorMapLibreMap</code> uses <a href="https://maplibre.org/" target="_blank" rel="noopener noreferrer">MapLibre GL JS</a>
        (open source, no vendor account required for the default demo style). Scripts load from unpkg on first use.
        The same .NET imperative API as Leaflet (markers, vectors, GeoJSON, tile overlays) is bridged to WebGL layers.
    </p>
    <div class="demo-map-wrap">
        <BlazorMapLibreMap @ref="_map"
                           Height="300px"
                           Options="@_options"
                           OnMapReady="OnMapReadyAsync"
                           OnViewChanged="OnViewChanged" />
    </div>
    <p class="demo-muted">@_viewSummary</p>
</section>

<section class="demo-panel">
    <h2>Try next</h2>
    <ul>
        <li><NavLink href="/maplibre/markers">Markers</NavLink></li>
        <li><NavLink href="/maplibre/vectors">Vectors</NavLink></li>
        <li><NavLink href="/maplibre/geojson">GeoJSON</NavLink></li>
        <li><NavLink href="/maplibre/tiles">Map styles (StyleUrl)</NavLink></li>
        <li><NavLink href="/maplibre/events">Events and layout</NavLink></li>
        <li><NavLink href="/maplibre/enterprise">Interaction toggles</NavLink></li>
    </ul>
</section>

<DemoCodeSample Title="Minimal MapLibre map" Code="@_snippet" />

@code {
    private BlazorMapLibreMap? _map;

    private readonly BlazorMapLibreMapOptions _options = new()
    {
        Center = new BlazorMapLatLng(51.5074, -0.1278),
        Zoom = 5,
    };

    private string _viewSummary = "Pan or zoom to see view state.";

    private const string _snippet =
        """
        <BlazorMapLibreMap Height="300px"
                           Options="@_options"
                           OnViewChanged="OnViewChanged" />

        @code {
            private readonly BlazorMapLibreMapOptions _options = new()
            {
                Center = new BlazorMapLatLng(51.5074, -0.1278),
                Zoom = 5,
                StyleUrl = "https://demotiles.maplibre.org/style.json",
            };
        }
        """;

    private async Task OnMapReadyAsync()
    {
        if (_map is null) return;
        await _map.AddMarkerAsync(new BlazorMapMarkerModel
        {
            Id = "london",
            Position = _options.Center,
            Title = "London",
            PopupHtml = "<strong>MapLibre GL</strong><br/>Default style needs no access token.",
        });
    }

    private Task OnViewChanged(BlazorMapViewState state)
    {
        _viewSummary = $"Center {state.Center.Latitude:F4}, {state.Center.Longitude:F4} · zoom {state.Zoom:F1}";
        StateHasChanged();
        return Task.CompletedTask;
    }
}
