@page "/geojson"

<PageTitle>BlazorMap — GeoJSON</PageTitle>

<h1>GeoJSON layer</h1>

<section class="demo-panel">
    <p>
        Pass any FeatureCollection-compatible GeoJSON string. Feature clicks forward
        <code>properties</code> as <code>JsonElement</code> for flexible binding.
    </p>
    <div class="demo-map-wrap">
        <BlazorLeafletMap @ref="_map"
                   Height="380px"
                   Options="@_opts"
                   OnGeoJsonFeatureClick="HandleGeoJsonFeatureClick" />
    </div>
    <div class="demo-actions">
        <button type="button" @onclick="LoadSampleAsync">Load sample</button>
        <button type="button" @onclick="ClearAsync">Remove layer</button>
    </div>
    <div class="demo-log">@_log</div>
</section>

@code {
    private BlazorLeafletMap? _map;
    private string _log = "Load the sample FeatureCollection, then click a feature.";

    private readonly MapDisplayOptions _opts = new()
    {
        Center = new LatLng(40.7128, -74.0060),
        Zoom = 11,
    };

    private const string SampleGeoJson = """
    {
      "type": "FeatureCollection",
      "features": [
        {
          "type": "Feature",
          "properties": { "name": "Downtown box" },
          "geometry": {
            "type": "Polygon",
            "coordinates": [[
              [-74.02, 40.72], [-73.98, 40.72], [-73.98, 40.75], [-74.02, 40.75], [-74.02, 40.72]
            ]]
          }
        },
        {
          "type": "Feature",
          "properties": { "name": "Uptown line" },
          "geometry": {
            "type": "LineString",
            "coordinates": [[-74.01, 40.78], [-73.99, 40.805], [-73.97, 40.82]]
          }
        }
      ]
    }
    """;

    private async Task LoadSampleAsync()
    {
        if (_map is null) return;
        await _map.RemoveLayerAsync("demo");
        await _map.AddGeoJsonAsync(
            "demo",
            SampleGeoJson,
            new VectorPathStyle { Color = "#a371f7", Weight = 3, FillOpacity = 0.25 });
        await _map.FitBoundsAsync(
            new LatLngBounds(new LatLng(40.71, -74.03), new LatLng(40.83, -73.96)));
        _log = "GeoJSON loaded. Click a feature.";
        StateHasChanged();
    }

    private async Task ClearAsync()
    {
        if (_map is null) return;
        await _map.RemoveLayerAsync("demo");
        _log = "Removed layer “demo”.";
        StateHasChanged();
    }

    private Task HandleGeoJsonFeatureClick((string LayerId, JsonElement Properties) e)
    {
        var name = e.Properties.TryGetProperty("name", out var n) ? n.GetString() : "(no name)";
        _log = $"Layer {e.LayerId}, properties.name = {name}";
        return Task.CompletedTask;
    }
}
