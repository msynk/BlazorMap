@page "/vectors"
@rendermode InteractiveWebAssembly

<PageTitle>BlazorMap — Vectors</PageTitle>

<h1>Polylines, polygons, circles, rectangles</h1>

<section class="demo-panel">
    <p>
        Vector layers are identified by a string <code>layerId</code> so you can remove or replace them individually.
        Click a shape to raise <code>OnVectorClick</code> (map clicks are stopped from bubbling when hitting a vector).
    </p>
    <div class="demo-map-wrap">
        <BlazorMap @ref="_map"
                   Height="380px"
                   Options="@_opts"
                   OnMapReady="InitialDrawAsync"
                   OnVectorClick="HandleVectorClick" />
    </div>
    <div class="demo-actions">
        <button type="button" @onclick="RedrawAsync">Redraw sample</button>
        <button type="button" @onclick="ClearAsync">Clear vectors</button>
    </div>
    <div class="demo-log">@_log</div>
</section>

@code {
    private BlazorMap? _map;
    private string _log = "Redraw loads a route, a park polygon, a circle, and a bounding box.";

    private readonly MapDisplayOptions _opts = new()
    {
        Center = new LatLng(37.7749, -122.4194),
        Zoom = 12,
    };

    private async Task InitialDrawAsync()
    {
        if (_map is null || !_map.IsMapReady) return;
        await RedrawCoreAsync();
    }

    private async Task RedrawAsync()
    {
        if (_map is null) return;
        await RedrawCoreAsync();
        StateHasChanged();
    }

    private async Task RedrawCoreAsync()
    {
        if (_map is null) return;
        await _map.ClearVectorLayersAsync();

        await _map.AddPolylineAsync(
            "route",
            [
                new LatLng(37.80, -122.42),
                new LatLng(37.79, -122.41),
                new LatLng(37.78, -122.40),
                new LatLng(37.77, -122.395),
            ],
            new VectorPathStyle { Color = "#f85149", Weight = 5, Opacity = 0.9 });

        await _map.AddPolygonAsync(
            "park",
            [
                new LatLng(37.769, -122.486),
                new LatLng(37.771, -122.475),
                new LatLng(37.765, -122.472),
                new LatLng(37.762, -122.482),
            ],
            new VectorPathStyle { Color = "#3fb950", FillOpacity = 0.35, Weight = 2 });

        await _map.AddCircleAsync(
            "radius",
            new LatLng(37.7849, -122.4094),
            radiusMeters: 900,
            new VectorPathStyle { Color = "#58a6ff", FillOpacity = 0.15, Weight = 2 });

        await _map.AddRectangleAsync(
            "box",
            new LatLngBounds(new LatLng(37.748, -122.44), new LatLng(37.756, -122.42)),
            new VectorPathStyle { Color = "#d29922", FillOpacity = 0.12, Weight = 2, DashArray = "6 4" });

        await _map.FitBoundsAsync(
            new LatLngBounds(new LatLng(37.755, -122.49), new LatLng(37.805, -122.38)));

        _log = "Sample vectors drawn. Click a shape to log its layer id.";
    }

    private async Task ClearAsync()
    {
        if (_map is null) return;
        await _map.ClearVectorLayersAsync();
        _log = "All vector layers cleared.";
    }

    private Task HandleVectorClick((string LayerId, string Kind, LatLng Position) e)
    {
        _log = $"{e.Kind} “{e.LayerId}” @ {e.Position.Lat:F5}, {e.Position.Lng:F5}";
        return Task.CompletedTask;
    }
}
