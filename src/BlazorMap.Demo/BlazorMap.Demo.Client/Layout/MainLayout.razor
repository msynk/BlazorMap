@inherits LayoutComponentBase

<div class="demo-shell">
    <header class="demo-header">
        <NavLink href="/" Match="NavLinkMatch.All" class="demo-brand">BlazorMap demo</NavLink>
        <nav class="demo-nav">
            <NavLink href="/" Match="NavLinkMatch.All">Overview</NavLink>
            <NavLink href="/markers">Markers</NavLink>
            <NavLink href="/vectors">Vectors</NavLink>
            <NavLink href="/geojson">GeoJSON</NavLink>
            <NavLink href="/tiles">Tiles</NavLink>
            <NavLink href="/events">Events</NavLink>
            <NavLink href="/enterprise">Enterprise</NavLink>
        </nav>
    </header>
    <main class="demo-main">
        @Body
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
