@inject NavigationManager Nav
@implements IDisposable

@{
    var path = new Uri(Nav.Uri).AbsolutePath.TrimEnd('/');
    var group =
        path.StartsWith("/leaflet", StringComparison.Ordinal) ? "leaflet"
        : path.StartsWith("/maplibre", StringComparison.Ordinal) ? "maplibre"
        : path.StartsWith("/mapbox", StringComparison.Ordinal) ? "mapbox"
        : path.StartsWith("/openlayers", StringComparison.Ordinal) ? "openlayers"
        : path.StartsWith("/arcgis", StringComparison.Ordinal) ? "arcgis"
        : path.StartsWith("/azuremaps", StringComparison.Ordinal) ? "azuremaps"
        : path.StartsWith("/cesium", StringComparison.Ordinal) ? "cesium"
        : null;
}

@if (group is not null)
{
    <nav class="demo-subnav" aria-label="Sample pages for @group">
        @if (group == "leaflet")
        {
            <NavLink class="demo-subnav-link" href="/leaflet" Match="NavLinkMatch.All">Overview</NavLink>
            <NavLink class="demo-subnav-link" href="/leaflet/markers">Markers</NavLink>
            <NavLink class="demo-subnav-link" href="/leaflet/vectors">Vectors</NavLink>
            <NavLink class="demo-subnav-link" href="/leaflet/geojson">GeoJSON</NavLink>
            <NavLink class="demo-subnav-link" href="/leaflet/tiles">Tiles</NavLink>
            <NavLink class="demo-subnav-link" href="/leaflet/events">Events</NavLink>
            <NavLink class="demo-subnav-link" href="/leaflet/enterprise">Enterprise</NavLink>
        }
        else if (group == "maplibre")
        {
            <NavLink class="demo-subnav-link" href="/maplibre" Match="NavLinkMatch.All">Overview</NavLink>
            <NavLink class="demo-subnav-link" href="/maplibre/markers">Markers</NavLink>
            <NavLink class="demo-subnav-link" href="/maplibre/vectors">Vectors</NavLink>
            <NavLink class="demo-subnav-link" href="/maplibre/geojson">GeoJSON</NavLink>
            <NavLink class="demo-subnav-link" href="/maplibre/tiles">Styles</NavLink>
            <NavLink class="demo-subnav-link" href="/maplibre/events">Events</NavLink>
            <NavLink class="demo-subnav-link" href="/maplibre/enterprise">Enterprise</NavLink>
        }
        else if (group == "mapbox")
        {
            <NavLink class="demo-subnav-link" href="/mapbox" Match="NavLinkMatch.All">Overview</NavLink>
            <NavLink class="demo-subnav-link" href="/mapbox/markers">Markers</NavLink>
            <NavLink class="demo-subnav-link" href="/mapbox/vectors">Vectors</NavLink>
            <NavLink class="demo-subnav-link" href="/mapbox/geojson">GeoJSON</NavLink>
            <NavLink class="demo-subnav-link" href="/mapbox/tiles">Styles</NavLink>
            <NavLink class="demo-subnav-link" href="/mapbox/events">Events</NavLink>
            <NavLink class="demo-subnav-link" href="/mapbox/enterprise">Enterprise</NavLink>
            <NavLink class="demo-subnav-link" href="/mapbox/token-help">Token help</NavLink>
        }
        else if (group == "openlayers")
        {
            <NavLink class="demo-subnav-link" href="/openlayers" Match="NavLinkMatch.All">Overview</NavLink>
            <NavLink class="demo-subnav-link" href="/openlayers/markers">Markers</NavLink>
            <NavLink class="demo-subnav-link" href="/openlayers/vectors">Vectors</NavLink>
            <NavLink class="demo-subnav-link" href="/openlayers/geojson">GeoJSON</NavLink>
            <NavLink class="demo-subnav-link" href="/openlayers/tiles">Tiles</NavLink>
            <NavLink class="demo-subnav-link" href="/openlayers/events">Events</NavLink>
            <NavLink class="demo-subnav-link" href="/openlayers/enterprise">Enterprise</NavLink>
        }
        else if (group == "arcgis")
        {
            <NavLink class="demo-subnav-link" href="/arcgis" Match="NavLinkMatch.All">Overview</NavLink>
            <NavLink class="demo-subnav-link" href="/arcgis/markers">Markers</NavLink>
            <NavLink class="demo-subnav-link" href="/arcgis/vectors">Vectors</NavLink>
            <NavLink class="demo-subnav-link" href="/arcgis/geojson">GeoJSON</NavLink>
            <NavLink class="demo-subnav-link" href="/arcgis/tiles">Basemaps</NavLink>
            <NavLink class="demo-subnav-link" href="/arcgis/events">Events</NavLink>
            <NavLink class="demo-subnav-link" href="/arcgis/enterprise">Enterprise</NavLink>
        }
        else if (group == "azuremaps")
        {
            <NavLink class="demo-subnav-link" href="/azuremaps" Match="NavLinkMatch.All">Overview</NavLink>
            <NavLink class="demo-subnav-link" href="/azuremaps/markers">Markers</NavLink>
            <NavLink class="demo-subnav-link" href="/azuremaps/vectors">Vectors</NavLink>
            <NavLink class="demo-subnav-link" href="/azuremaps/geojson">GeoJSON</NavLink>
            <NavLink class="demo-subnav-link" href="/azuremaps/tiles">Styles</NavLink>
            <NavLink class="demo-subnav-link" href="/azuremaps/events">Events</NavLink>
            <NavLink class="demo-subnav-link" href="/azuremaps/enterprise">Enterprise</NavLink>
        }
        else if (group == "cesium")
        {
            <NavLink class="demo-subnav-link" href="/cesium" Match="NavLinkMatch.All">Overview</NavLink>
            <NavLink class="demo-subnav-link" href="/cesium/markers">Markers</NavLink>
            <NavLink class="demo-subnav-link" href="/cesium/vectors">Vectors</NavLink>
            <NavLink class="demo-subnav-link" href="/cesium/geojson">GeoJSON</NavLink>
            <NavLink class="demo-subnav-link" href="/cesium/tiles">Imagery</NavLink>
            <NavLink class="demo-subnav-link" href="/cesium/events">Events</NavLink>
            <NavLink class="demo-subnav-link" href="/cesium/enterprise">3D Options</NavLink>
        }
    </nav>
}

@code {
    protected override void OnInitialized() => Nav.LocationChanged += OnLocationChanged;

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e) => _ = InvokeAsync(StateHasChanged);

    public void Dispose() => Nav.LocationChanged -= OnLocationChanged;
}
